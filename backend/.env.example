# Hidden Depths - Backend Environment Variables
# Copy this file to .env and fill in the values

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=8081
ENVIRONMENT=development

# =============================================================================
# DATABASE - Supabase PostgreSQL Connection String
# =============================================================================
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/hidden_depths

# =============================================================================
# AUTHENTICATION
# =============================================================================
# JWT secret for signing tokens (min 32 chars recommended)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# Supabase anon key for verifying client tokens
SUPABASE_ANON_KEY=your-supabase-anon-key

# Comma-separated list of admin email addresses
ADMIN_EMAILS=admin@example.com

# =============================================================================
# PAYMENTS - Razorpay
# =============================================================================
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret-key

# =============================================================================
# CACHING - Redis (Optional)
# =============================================================================
# Leave empty to disable Redis caching
REDIS_URL=
CACHE_ENABLED=false

# =============================================================================
# CORS - Allowed Origins
# =============================================================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://hidden-depths-web.pages.dev
